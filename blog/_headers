# Cloudflare Pages — long cache for content-hashed build assets.
# Astro emits files under /_astro/* with hashed filenames, so they
# are safe to cache aggressively (immutable).

# Security headers — apply to all routes.
/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images & favicons — hashed at the source level; long cache.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
*.webp
  Cache-Control: public, max-age=31536000, immutable

# HTML & feeds — short, revalidated.
/*.html
  Cache-Control: public, max-age=300, s-maxage=3600
/
  Cache-Control: public, max-age=300, s-maxage=3600
/rss.xml
  Cache-Control: public, max-age=600
/sitemap-index.xml
  Cache-Control: public, max-age=3600
